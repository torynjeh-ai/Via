PORT=3000
NODE_ENV=production

# Database (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-web-app.up.railway.app,https://yourdomain.com

# Twilio (OTP SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# MTN Mobile Money
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key

# Orange Money
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay
ORANGE_MONEY_CLIENT_ID=your_client_id
ORANGE_MONEY_CLIENT_SECRET=your_client_secret

# Face Verification Microservice (optional)
FACE_SERVICE_URL=https://your-face-service.up.railway.app
